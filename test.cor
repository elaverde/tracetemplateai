function primosYParesHasta(n) {
  const primos = [];
  crerror(#file, #line, "[DEBUG][primosYParesHasta] primos" + primos);
  const pares = [];
  crerror(#file, #line, "[DEBUG][primosYParesHasta] pares" + pares);
  const primosPares = [];
  crerror(#file, #line, "[DEBUG][primosYParesHasta] primosPares" + primosPares);
  for (let i = 2; i <= n; i++) {
    // Verifica si es primo
    let esPrimo = true;
    crerror(#file, #line, "[DEBUG][primosYParesHasta] esPrimo" + esPrimo);
    for (let j = 2; j <= Math.sqrt(i); j++) {
      crerror(#file, #line, "[DEBUG][primosYParesHasta] i % j === 0" + i % j === 0);
      if (i % j === 0) {
        esPrimo = false;
        crerror(#file, #line, "[DEBUG][primosYParesHasta] esPrimo" + esPrimo);
        break;
      }
    }
    crerror(#file, #line, "[DEBUG][primosYParesHasta] esPrimo" + esPrimo);
    if (esPrimo) primos.push(i);
    crerror(#file, #line, "[DEBUG][primosYParesHasta] i % 2 === 0" + i % 2 === 0);
    if (i % 2 === 0) pares.push(i);
    crerror(#file, #line, "[DEBUG][primosYParesHasta] esPrimo && i % 2 === 0" + esPrimo && i % 2 === 0);
    if (esPrimo && i % 2 === 0) primosPares.push(i);
  }
  return {
    primos,
    pares,
    primosPares
  };
  }
  // Función rara con variables y trazas
  function funcionRaraConVariables(n) {
    let resultado = 0;
    let s = "";
    let arr = [];
    let x = Math.random() * n;
    s += "Inicio: " + x;
    console.log("[TRACE][funcionRaraConVariables] s=" + s);
    for (let i = 0; i < n; i++) {
      let v = (i % 3 === 0) ? x * i : x / (i + 1);
      arr.push(v);
      s += ",v=" + v;
      if (v > 10) {
        resultado += v;
        s += "[+10]";
      } else {
        resultado -= v;
        s += "[-10]";
      }
      if (i % 2 === 1) {
        s = s.split('').reverse().join('');
        console.log("[TRACE][funcionRaraConVariables] s (reversed)=" + s);
      } else {
        console.log("[TRACE][funcionRaraConVariables] s=" + s);
      }
    }
    console.log("[TRACE][funcionRaraConVariables] resultado final=" + resultado);
    return { resultado, s, arr };
  }
}